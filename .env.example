# Sharing uses a serverless Redis (KV) database.
# When you connect Upstash Redis (via the Vercel Storage tab, or the
# Vercel + Upstash integration), these are injected automatically — you
# do NOT need to fill them in by hand for a Vercel deployment.
#
# The app reads whichever of these pairs is present, so it works whether
# the credentials are exposed under the classic "KV_" names or the
# "UPSTASH_REDIS_" names. See README.md → "Enable sharing".

# Classic Vercel KV names
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Upstash (Marketplace / Upstash integration) names
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# For local development, copy ONE matching pair from your Vercel
# project's Settings → Environment Variables into a .env.local file.
